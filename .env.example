# Frontend
# Leave blank when frontend and API share the same host through Kubernetes Ingress.
VITE_API_BASE_URL=

# Shared backend auth
JWT_SECRET=replace-with-a-long-random-secret

# Auth service
AUTH_PORT=4001
AUTH_MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/task_management_auth
AUTH_CORS_ORIGIN=

# Task service
TASK_PORT=4002
TASK_MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/task_management_tasks
TASK_CORS_ORIGIN=
